# TripMate Test Environment Config
# Copy this to .env and fill in your values — never commit .env to GitHub

# App URLs
BASE_URL=https://tripmateapp.netlify.app
API_BASE_URL=https://tripmateapp.netlify.app/.netlify/functions

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Test User Credentials
TEST_USER_EMAIL=testuser@tripmate.com
TEST_USER_PASSWORD=TestPassword123!
TEST_USER_NAME=TripMate Tester

# Browser Settings
HEADLESS=true
SLOW_MO=0

# Timeouts (milliseconds)
DEFAULT_TIMEOUT=30000
API_TIMEOUT=60000
